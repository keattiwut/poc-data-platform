<!-- Native Prometheus metrics endpoint (Issue 08 / ADR-0008): scraped by the
     prometheus service at clickhouse:9363/metrics. -->
<clickhouse>
    <prometheus>
        <endpoint>/metrics</endpoint>
        <port>9363</port>
        <metrics>true</metrics>
        <events>true</events>
        <asynchronous_metrics>true</asynchronous_metrics>
    </prometheus>
</clickhouse>
