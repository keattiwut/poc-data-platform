{
  "title": "Pipeline Infra Health",
  "uid": "infra-health",
  "tags": ["payment-gateway", "infra"],
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Service Up",
      "type": "stat",
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "up", "legendFormat": "{{job}}", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "green", "value": 1}
          ]},
          "mappings": [{"type": "value", "options": {
            "0": {"text": "DOWN", "color": "red"},
            "1": {"text": "UP", "color": "green"}
          }}]
        }
      }
    },
    {
      "id": 2,
      "title": "ClickHouse queries/sec",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "rate(ClickHouseProfileEvents_Query[5m])", "legendFormat": "queries/s", "refId": "A"}]
    },
    {
      "id": 3,
      "title": "MinIO usable free bytes",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "minio_cluster_capacity_usable_free_bytes", "legendFormat": "free bytes", "refId": "A"}]
    },
    {
      "id": 4,
      "title": "Airflow task failures (rate)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "rate(airflow_ti_failures[15m])", "legendFormat": "failures/s", "refId": "A"}]
    },
    {
      "id": 5,
      "title": "Service logs (Loki)",
      "type": "logs",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 14},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "{container=~\"clickhouse|airflow-scheduler|minio|kafka|superset\"}", "refId": "A"}],
      "options": {"showTime": true, "wrapLogMessage": true}
    }
  ]
}
